@model IEnumerable<Dimakotso_Construction.Models.StudentEnrollment>
@using Dimakotso_Construction.Models.Enums

@{
    ViewData["Title"] = "QCTO Student Information Dashboard";
}

<style>
    .stat-card {
        background: #fff;
        border-radius: 12px;
        padding: 20px;
        border: 1px solid #eef2f6;
        transition: 0.3s;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 10px;
    }

        .stat-card .icon-box {
            width: 50px;
            height: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
            font-size: 1.5rem;
            margin-bottom: 5px;
        }

        .stat-card h3 {
            font-weight: 700;
            color: #2c3e50;
            margin: 0;
        }

        .stat-card p {
            color: #7f8c8d;
            font-size: 0.85rem;
            margin: 0;
        }

    .welcome-banner {
        background: #ffffff;
        padding: 25px;
        border-radius: 12px;
        margin-bottom: 25px;
        border: 1px solid #eef2f6;
    }
</style>

<div class="container-fluid py-4" style="background-color: #fcfcfc;">
    <div class="welcome-banner shadow-sm">
        <h4 class="fw-bold">Welcome back</h4>
        <p class="text-muted">Here's what's happening in your dashboard today.</p>
    </div>

    <div class="row g-3 mb-5">
        <!-- Row 1 -->
        <div class="col-md-3"><div class="stat-card shadow-sm"><div class="icon-box bg-primary bg-opacity-10 text-primary"><i class="bi bi-person-badge"></i></div><h3>@ViewBag.TotalStudents</h3><p>Total Records</p></div></div>
        <div class="col-md-3"><div class="stat-card shadow-sm"><div class="icon-box bg-success bg-opacity-10 text-success"><i class="bi bi-briefcase"></i></div><h3>@ViewBag.ActiveTraining</h3><p>Active Learners</p></div></div>
        <div class="col-md-3"><div class="stat-card shadow-sm"><div class="icon-box bg-info bg-opacity-10 text-info"><i class="bi bi-book"></i></div><h3>0</h3><p>Active Courses</p></div></div>
        <div class="col-md-3"><div class="stat-card shadow-sm"><div class="icon-box bg-secondary bg-opacity-10 text-secondary"><i class="bi bi-patch-check"></i></div><h3>0</h3><p>Total Certificates</p></div></div>

        <!-- Row 2 -->
        <div class="col-md-3"><div class="stat-card shadow-sm"><div class="icon-box bg-primary bg-opacity-10 text-primary"><i class="bi bi-shield-check"></i></div><h3>0</h3><p>Active Certs</p></div></div>
        <div class="col-md-3"><div class="stat-card shadow-sm"><div class="icon-box bg-warning bg-opacity-10 text-warning"><i class="bi bi-calendar-event"></i></div><h3>0</h3><p>Issued This Month</p></div></div>
        <div class="col-md-3"><div class="stat-card shadow-sm"><div class="icon-box bg-primary bg-opacity-10 text-primary"><i class="bi bi-calendar-minus"></i></div><h3>0</h3><p>Issued Last Month</p></div></div>
        <div class="col-md-3"><div class="stat-card shadow-sm"><div class="icon-box bg-danger bg-opacity-10 text-danger"><i class="bi bi-exclamation-triangle"></i></div><h3>0</h3><p>Expiring Soon</p></div></div>
    </div>
</div>