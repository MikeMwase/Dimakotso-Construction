@model Dimakotso_Construction.Models.Employer

@{
    ViewData["Title"] = "Delete Employer";
}

<div class="container mt-4">
    <div class="card shadow-sm border-danger">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">Delete Employer</h4>
        </div>
        <div class="card-body">
            <h5 class="text-danger">Are you sure you want to delete this?</h5>
            <p>This action cannot be undone.</p>
            <hr />

            <dl class="row">
                <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(model => model.CompanyName)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.CompanyName)</dd>

                <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(model => model.ContactPerson)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.ContactPerson)</dd>

                <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(model => model.Sector)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Sector)</dd>

                <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(model => model.City)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.City), @Html.DisplayFor(model => model.Province)</dd>

                <dt class="col-sm-3 fw-bold">@Html.DisplayNameFor(model => model.Status)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Status)</dd>
            </dl>
        </div>
        <div class="card-footer bg-light">
            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger px-4">Confirm Delete</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
            </form>
        </div>
    </div>
</div>