@model IEnumerable<Dimakotso_Construction.Models.Employer>

@{
    ViewData["Title"] = "Employers List";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Employers</h1>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Create New</a>
</div>

<div class="table-responsive">
    <table class="table table-hover table-striped border">
        <thead class="table-dark">
            <tr>
                <th>@Html.DisplayNameFor(model => model.CompanyName)</th>
                <th>Contact</th>
                <th>Sector</th>
                <th>Location</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.CompanyName</strong></td>
                    <td>
                        <small>@item.ContactPerson</small><br />
                        <small class="text-muted">@item.ContactEmail</small>
                    </td>
                    <td>@item.Sector</td>
                    <td>@item.City, @item.Province</td>
                    <td><span class="badge bg-success">@item.Status</span></td>
                    <td>
                        <div class="btn-group btn-group-sm">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary">Edit</a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info">Details</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger">Delete</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>