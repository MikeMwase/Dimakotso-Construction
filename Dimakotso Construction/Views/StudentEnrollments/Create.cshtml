@model Dimakotso_Construction.Models.StudentEnrollment

@{
    ViewData["Title"] = "Register New Student";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <span class="badge bg-primary px-3 py-2 rounded-pill text-uppercase tracking-wider mb-2">Registration Desk</span>
            <h1 class="h3 fw-bold text-dark m-0">New Student Intake & Compliance Profile</h1>
            <p class="text-muted small mb-0">Capture required SAQA data vectors and operational lifecycle alignments.</p>
        </div>
        <div>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm fw-semibold d-flex align-items-center gap-1">
                <i class="bi bi-arrow-left-circle-fill"></i> Back to List
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 12px; overflow: hidden;">
        <div class="card-header bg-dark text-white py-3 px-4">
            <h5 class="mb-0 fw-bold d-flex align-items-center gap-2">
                <i class="bi bi-person-plus-fill"></i> Fresh Enrollment Record Database Entry
            </h5>
        </div>

        <div class="card-body p-4 bg-white">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <h6 class="text-primary fw-bold border-bottom pb-2 mb-3 text-uppercase small tracking-wider">System References</h6>
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <label asp-for="RegistrationNumber" class="form-label fw-semibold small text-muted"></label>
                        <input asp-for="RegistrationNumber" class="form-control font-monospace" placeholder="e.g. DC-2026-001" />
                        <span asp-validation-for="RegistrationNumber" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="SaqaId" class="form-label fw-semibold small text-muted"></label>
                        <input asp-for="SaqaId" class="form-control font-monospace" />
                        <span asp-validation-for="SaqaId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="DateCreated" class="form-label fw-semibold small text-muted"></label>
                        <input asp-for="DateCreated" class="form-control" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        <span asp-validation-for="DateCreated" class="text-danger small"></span>
                    </div>
                </div>

                <h6 class="text-primary fw-bold border-bottom pb-2 mb-3 text-uppercase small tracking-wider">Personal Identity Information</h6>
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <label asp-for="FirstNames" class="form-label fw-semibold small text-muted"></label>
                        <input asp-for="FirstNames" class="form-control" />
                        <span asp-validation-for="FirstNames" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Surname" class="form-label fw-semibold small text-muted"></label>
                        <input asp-for="Surname" class="form-control" />
                        <span asp-validation-for="Surname" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="IdentificationNumber" class="form-label fw-semibold small text-muted"></label>
                        <input asp-for="IdentificationNumber" class="form-control font-monospace" />
                        <span asp-validation-for="IdentificationNumber" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <label asp-for="DateOfBirth" class="form-label fw-semibold small text-muted"></label>
                        <input asp-for="DateOfBirth" class="form-control" type="date" />
                        <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Gender" class="form-label fw-semibold small text-muted"></label>
                        <input asp-for="Gender" class="form-control" />
                        <span asp-validation-for="Gender" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Equity" class="form-label fw-semibold small text-muted"></label>
                        <select asp-for="Equity" class="form-select"></select>
                        <span asp-validation-for="Equity" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <label asp-for="Citizenship" class="form-label fw-semibold small text-muted"></label>
                        <select asp-for="Citizenship" class="form-select"></select>
                        <span asp-validation-for="Citizenship" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="DisabilityStatus" class="form-label fw-semibold small text-muted"></label>
                        <select asp-for="DisabilityStatus" class="form-select"></select>
                        <span asp-validation-for="DisabilityStatus" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="CurrentEmployment" class="form-label fw-semibold small text-muted"></label>
                        <select asp-for="CurrentEmployment" class="form-select"></select>
                        <span asp-validation-for="CurrentEmployment" class="text-danger small"></span>
                    </div>
                </div>

                <h6 class="text-primary fw-bold border-bottom pb-2 mb-3 text-uppercase small tracking-wider">Contact & Communications</h6>
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <label asp-for="Email" class="form-label fw-semibold small text-muted"></label>
                        <input asp-for="Email" class="form-control" type="email" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="MobileNumber" class="form-label fw-semibold small text-muted"></label>
                        <input asp-for="MobileNumber" class="form-control" />
                        <span asp-validation-for="MobileNumber" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="PostalCode" class="form-label fw-semibold small text-muted"></label>
                        <input asp-for="PostalCode" class="form-control" />
                        <span asp-validation-for="PostalCode" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="HomeAddress" class="form-label fw-semibold small text-muted"></label>
                    <input asp-for="HomeAddress" class="form-control" />
                    <span asp-validation-for="HomeAddress" class="text-danger small"></span>
                </div>

                <h6 class="text-primary fw-bold border-bottom pb-2 mb-3 text-uppercase small tracking-wider">Academic Placement Profile</h6>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="HighestQualification" class="form-label fw-semibold small text-muted"></label>
                        <input asp-for="HighestQualification" class="form-control" />
                        <span asp-validation-for="HighestQualification" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="TargetProgramTitle" class="form-label fw-semibold small text-muted"></label>
                        <input asp-for="TargetProgramTitle" class="form-control" />
                        <span asp-validation-for="TargetProgramTitle" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="WorkplacePlacementId" class="form-label fw-semibold small text-muted"></label>
                        <select asp-for="WorkplacePlacementId" class="form-select" asp-items="ViewBag.WorkplacePlacementId"></select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Status" class="form-label fw-semibold small text-muted"></label>
                        <select asp-for="Status" class="form-select"></select>
                        <span asp-validation-for="Status" class="text-danger small"></span>
                    </div>
                </div>

                <div class="bg-light p-3 rounded mb-4 border">
                    <div class="form-check form-switch m-0">
                        <input class="form-check-input" type="checkbox" role="switch" asp-for="HasConsentedToPopiaDataSharing" id="popiaConsentCheck" />
                        <label class="form-check-label fw-bold text-dark small ms-2" for="popiaConsentCheck">
                            POPIA Statutory Compliance Legal Disclaimer & Data Sharing Consent
                        </label>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 border-top pt-3">
                    <a asp-action="Index" class="btn btn-light px-4 border">Cancel</a>
                    <button type="submit" class="btn btn-primary px-5 fw-semibold">
                        <i class="bi bi-check-circle-fill"></i> Complete Enrollment
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}