@model Dimakotso_Construction.Models.StudentEnrollment
@using Dimakotso_Construction.Models.Enums

@{
    ViewData["Title"] = "Modify Student Profile";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <span class="badge bg-secondary px-3 py-2 rounded-pill text-uppercase tracking-wider mb-2">Data Administration</span>
            <h1 class="h3 fw-bold text-dark m-0">Edit Student Compliance Profile</h1>
            <p class="text-muted small mb-0">Updating regulatory details for Tracking Reference: <span class="font-monospace fw-bold text-primary">@Model.RegistrationNumber</span></p>
        </div>
        <div>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm fw-semibold d-flex align-items-center gap-1">
                <i class="bi bi-arrow-left-circle-fill"></i> Back to List
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 12px; overflow: hidden;">
        <div class="card-header bg-dark text-white py-3 px-4">
            <h5 class="mb-0 fw-bold d-flex align-items-center gap-2">
                <i class="bi bi-person-lines-fill"></i> Core Enrollment Record Database Information
            </h5>
        </div>

        <div class="card-body p-4 bg-white">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                <input type="hidden" asp-for="Id" />

                <h6 class="text-primary fw-bold border-bottom pb-2 mb-3 text-uppercase small tracking-wider">System References</h6>
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <label asp-for="RegistrationNumber" class="form-label fw-semibold small text-muted"></label>
                        <input asp-for="RegistrationNumber" class="form-control font-monospace" readonly style="background-color: #f8f9fa;" />
                        <span asp-validation-for="RegistrationNumber" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="SaqaId" class="form-label fw-semibold small text-muted">SAQA Qualification ID</label>
                        <input asp-for="SaqaId" class="form-control font-monospace" />
                        <span asp-validation-for="SaqaId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="DateCreated" class="form-label fw-semibold small text-muted">Record Entry Date</label>
                        <input asp-for="DateCreated" class="form-control" type="date" readonly style="background-color: #f8f9fa;" />
                        <span asp-validation-for="DateCreated" class="text-danger small"></span>
                    </div>
                </div>

                <h6 class="text-primary fw-bold border-bottom pb-2 mb-3 text-uppercase small tracking-wider">Personal Identity Information</h6>
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <label asp-for="FirstNames" class="form-label fw-semibold small text-muted">First Name(s)</label>
                        <input asp-for="FirstNames" class="form-control" />
                        <span asp-validation-for="FirstNames" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Surname" class="form-label fw-semibold small text-muted">Surname</label>
                        <input asp-for="Surname" class="form-control" />
                        <span asp-validation-for="Surname" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="IdentificationNumber" class="form-label fw-semibold small text-muted">National ID / Passport</label>
                        <input asp-for="IdentificationNumber" class="form-control font-monospace" />
                        <span asp-validation-for="IdentificationNumber" class="text-danger small"></span>
                    </div>
                </div>

                <h6 class="text-primary fw-bold border-bottom pb-2 mb-3 text-uppercase small tracking-wider">Academic Placement Profile</h6>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="TargetProgramTitle" class="form-label fw-semibold small text-muted">Registered Trade Occupational Program Title</label>
                        <input asp-for="TargetProgramTitle" class="form-control" />
                        <span asp-validation-for="TargetProgramTitle" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="WorkplacePlacementId" class="form-label fw-semibold small text-muted">Assigned Workplace Host Employer</label>
                        <select asp-for="WorkplacePlacementId" class="form-select" asp-items="ViewBag.WorkplacePlacementId"></select>
                        <span asp-validation-for="WorkplacePlacementId" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Status" class="form-label fw-semibold small text-muted">Operational Enrollment Lifecycle Status</label>
                    <select asp-for="Status" class="form-select fw-bold text-primary"></select>
                    <span asp-validation-for="Status" class="text-danger small"></span>
                </div>

                <div class="bg-light p-3 rounded mb-4 border">
                    <div class="form-check form-switch m-0">
                        <input class="form-check-input" type="checkbox" role="switch" asp-for="HasConsentedToPopiaDataSharing" id="popiaConsentCheck" />
                        <label class="form-check-label fw-bold text-dark small ms-2" for="popiaConsentCheck">
                            POPIA Statutory Compliance Legal Disclaimer & Data Sharing Consent
                        </label>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 border-top pt-3">
                    <a asp-action="Index" class="btn btn-light px-4 border">Cancel</a>
                    <button type="submit" class="btn btn-primary px-5 fw-semibold">
                        <i class="bi bi-save-fill"></i> Save Dynamic Modifications
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}