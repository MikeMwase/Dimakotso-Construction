@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Dimakotso Construction</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css">

    <style>
        :root {
            --navy: #0f1e3d;
            --gold: #c8922a;
            --gold-light: #f5c96e;
            --off-white: #faf8f3;
            --text-dark: #1a1a2e;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--off-white);
            margin: 0;
            display: flex;
            min-height: 100vh;
        }

        /* ── SIDEBAR NAV ── */
        .site-nav {
            background: var(--navy);
            width: 260px;
            padding: 40px 20px;
            display: flex;
            flex-direction: column;
            gap: 40px;
            border-right: 2px solid var(--gold);
            position: sticky;
            top: 0;
            height: 100vh;
            flex-shrink: 0;
        }

        .nav-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
        }

        .nav-logo-icon {
            width: 36px;
            height: 36px;
            border-radius: 6px;
            background: var(--gold);
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .nav-logo-icon img {
                width: 28px;
                height: 28px;
                object-fit: contain;
            }

        .nav-brand-text {
            display: flex;
            flex-direction: column;
        }

        .nav-brand {
            font-family: 'Playfair Display', serif;
            color: #fff;
            font-size: 17px;
            font-weight: 700;
        }

        .nav-sub {
            color: var(--gold-light);
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
        }

        .nav-links {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

            .nav-links a {
                color: rgba(255,255,255,0.75);
                text-decoration: none;
                font-size: 14px;
                transition: 0.2s;
            }

                .nav-links a:hover {
                    color: var(--gold-light);
                }

        .nav-portal {
            color: var(--gold-light) !important;
            font-weight: 600;
            border: 1px solid var(--gold);
            padding: 8px 14px;
            border-radius: 4px;
            text-align: center;
        }

        .nav-cta {
            background: var(--gold);
            color: var(--navy) !important;
            font-weight: 500;
            padding: 8px 14px;
            border-radius: 4px;
            text-align: center;
        }

        .nav-logout-btn {
            background: transparent;
            border: 1px solid rgba(255,255,255,0.2);
            color: rgba(255,255,255,0.75);
            padding: 8px;
            border-radius: 4px;
            cursor: pointer;
            width: 100%;
        }

        /* ── CONTENT AREA ── */
        .content-wrapper {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
        }

        main {
            flex: 1;
            padding: 40px;
        }

        .site-footer {
            background: #0a1428;
            border-top: 2px solid var(--gold);
            padding: 40px;
            color: rgba(255,255,255,0.45);
            font-size: 13px;
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <nav class="site-nav">
        <a class="nav-logo" href="/">
            <div class="nav-logo-icon"><img src="~/images/page1_img2.jpeg" alt="Logo" /></div>
            <div class="nav-brand-text">
                <span class="nav-brand">Dimakotso Construction</span>
                <span class="nav-sub">Training Center</span>
            </div>
        </a>

        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/#mission">About</a>
            <a href="/#programmes">Programmes</a>

            @if (SignInManager.IsSignedIn(User))
            {
                <hr class="text-white-50" />
                <a asp-area="" asp-controller="Dashboard" asp-action="Index" class="nav-portal">
                    <i class="bi bi-shield-lock-fill me-1"></i>Internal Portal
                </a>

                <a asp-controller="Employers" asp-action="Index">
                    <i class="bi bi-building me-2"></i>Manage Employers
                </a>

                <a asp-controller="StudentEnrollments" asp-action="Index">
                    <i class="bi bi-people me-2"></i>Student Learners
                </a>

                <a asp-controller="Assessors" asp-action="Index">
                    <i class="bi bi-person-badge me-2"></i>Assessors
                </a>

                <span class="text-white-50 small"><i class="bi bi-person-circle me-1"></i>@User.Identity!.Name</span>
                <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                    <button type="submit" class="nav-logout-btn">Logout</button>
                </form>
            }
            else
            {
                <hr class="text-white-50" />
                <a asp-area="Identity" asp-page="/Account/Login" class="nav-portal">Login</a>
                <a href="/#contact" class="nav-cta">Get Certified</a>
            }
        </div>
    </nav>

    <div class="content-wrapper">
        <main role="main">
            @RenderBody()
        </main>

        <footer class="site-footer">
            <span>&copy; @DateTime.Now.Year Dimakotso Construction. All rights reserved.</span>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>